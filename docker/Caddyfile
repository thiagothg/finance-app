{
	frankenphp

	# Disable HTTPS in local development (set SERVER_NAME to enable auto-HTTPS)
	auto_https off
}

:80 {
	# Set the webroot to the Laravel public/ directory
	root * /app/public

	# Enable compression
	encode zstd br gzip

	# Execute PHP files and serve static assets
	php_server {
		try_files {path} index.php
	}
}
